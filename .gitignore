# =============================================================================
# LiveLegal AI — .gitignore
# Covers: Python (RAG service), Node.js (Express backend), OS files
# =============================================================================


# =============================================================================
# SECRETS — NEVER COMMIT THESE
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/


# =============================================================================
# PYTHON
# =============================================================================

# Virtual environments
venv/
.venv/
env/
ENV/
rag_service/venv/
rag_service/.venv/

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/

# pytest / test caches
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy / type checking
.mypy_cache/
.dmypy.json

# Jupyter Notebooks
.ipynb_checkpoints/

# pyenv
.python-version


# =============================================================================
# RAG SERVICE — GENERATED DATA (large, local-only)
# =============================================================================

# FAISS vector indexes (regenerated by /ingest — not source code)
rag_service/faiss_indexes/

# Uploaded files (temporary — deleted after ingestion, but just in case)
rag_service/uploaded_files/

# Downloaded ML models (SentenceTransformers caches here)
rag_service/.cache/
.cache/


# =============================================================================
# NODE.JS / EXPRESS BACKEND
# =============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/

# Build output
dist/
build/
.next/
out/

# Package lock files — keep only one (comment out whichever you don't use)
# package-lock.json
# yarn.lock

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/


# =============================================================================
# EDITORS & IDEs
# =============================================================================

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws

# Vim / Emacs
*.swp
*.swo
*~
\#*\#


# =============================================================================
# OPERATING SYSTEM
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
*.log.*


# =============================================================================
# MISC
# =============================================================================

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.orig

# Zip / archives
*.zip
*.tar.gz
*.rar


# Python
rag_service/.venv/
rag_service/__pycache__/
rag_service/*.pyc

# Node
backend/node_modules/
frontend/node_modules/

# Environment files
.env
*.local

# IDE
.vscode/
.idea/