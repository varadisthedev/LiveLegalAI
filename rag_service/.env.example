ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: Set to true to use OpenAI embeddings instead of SentenceTransformers
USE_OPENAI_EMBEDDINGS=false
OPENAI_API_KEY=your_openai_api_key_here

# Claude model to use (claude-3-5-sonnet-20241022 is recommended)
CLAUDE_MODEL=
# SentenceTransformer model (used when USE_OPENAI_EMBEDDINGS=false)
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Storage paths (relative to rag_service/)
FAISS_INDEX_DIR=./faiss_indexes
UPLOAD_DIR=./uploaded_files

# Chunking parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# How many chunks to retrieve per query
TOP_K_CHUNKS=5

# Max upload file size in MB
MAX_FILE_SIZE_MB=20
